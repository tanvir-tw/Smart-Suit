            <property name="dataSource">Data Source</property>
            <xml-property name="queryText"><![CDATA[select SrNo, name,branch,contact,email,cast(commission as decimal(10,2)) as commission,Location,date_format(validfrom,"%d-%b-%Y") as validfrom,date_format(validto,"%d-%b-%Y") as validto,remark,EntryBy,date_format(entrydatetime,"%d-%b-%Y") as entrydatetime,status from 100015collectionStaffMaster where entrydatetime between ? and ?  and Status='Active']]></xml-property>
