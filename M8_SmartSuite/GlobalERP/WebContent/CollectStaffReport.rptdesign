                        <list-property name="sort">
                            <structure>
                                <expression name="key" type="javascript">if ( params["SortKey"].value == "SrNo"){
row["SrNo"];
}else if ( params["SortKey"].value == "name"){
row["name"];
}else if ( params["SortKey"].value == "Branch"){
row["Branch"];
}else if ( params["SortKey"].value == "ContactNo"){
row["ContactNo"];
}else if ( params["SortKey"].value == "email"){
row["email"];
}else if ( params["SortKey"].value == "commission"){
row["commission"];
}else if ( params["SortKey"].value == "Location"){
row["Location"];
}else if ( params["SortKey"].value == "remark"){
row["remark"];
}else if ( params["SortKey"].value == "EntryBy"){
row["EntryBy"];
}else if ( params["SortKey"].value == "status"){
row["status"];
}</expression>
                                <property name="direction">asc</property>
