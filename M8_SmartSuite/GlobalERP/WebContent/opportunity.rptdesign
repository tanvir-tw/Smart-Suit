            <xml-property name="queryText"><![CDATA[select custtype,Opportunitycode,Address,opportunitycount,companyname,customercode,City,Zip,State,Country,ContactPerson,Phone,Fax,Email,WebSite,WeeklyOffOn,Category,STDCode,MobileNo,ResiNo,Comments,OpportunityName,insertDate,DATE_FORMAT(UpdatedDate,'%d-%b-%Y %H:%i') as UpdatedDate,EntryBy,alternatenumber,Assignto,LeadRefNo,product,potentialValue,noofunits from db_GlobalERP.100000newopportunity where UpdatedDate>='dt' and UpdatedDate<='dt1' and companyname='dt3']]></xml-property>
