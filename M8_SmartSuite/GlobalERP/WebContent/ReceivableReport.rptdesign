            <property name="dataSource">Data Source</property>
            <xml-property name="queryText"><![CDATA[Select ProspCustName, DATE_FORMAT(AmountExpectedOn,'%d-%b-%Y') as AmountExpectedOn,AmountExpected, DATE_FORMAT(FollowUpDate,'%d-%b-%Y') as FollowUpDate,(select EmpName from db_GlobalERP.100000security where EmpCode=MarketingRepcode) as EmpName,Comments from db_GlobalERP.100000followup where PaymentFollowup='Yes' and AmountExpectedOn between ? and ?]]></xml-property>
