            <method name="beforeOpen"><![CDATA[this.queryText=this.queryText.replace("conditionhere",params["condition1"]);
this.queryText=this.queryText.replace("100000",params["companyid"]);
this.queryText=this.queryText.replace("TWEmpname=''","TWEmpname like '%%'");]]></method>
            <property name="dataSource">Data Source</property>
            <xml-property name="queryText"><![CDATA[SELECT DISTINCT SalesquoRefNo,Date_Format(SalesQuoDate, '%d-%b-%Y') as SalesQuoDate,SalesQuoCancelled,CompanyName,(SELECT TheGroupName FROM db_GlobalERP.100000tbl_groupmaster where TheGroupCode=TheGroup) as TheGroup, ThisIsSalesOrder,Total,TWEmpname,Quotationtype,SalesQuoNo FROM db_GlobalERP.100000salesquo_det where conditionhere ORDER BY SalesQuoNo DESC]]></xml-property>
